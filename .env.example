# Versa · 环境变量模板 (v20.0)
# 复制为 .env 后填入实际值

# ====== App ======
NODE_ENV=production
VITE_APP_VERSION=20.0.0
VITE_BASE_URL=/versa/

# ====== Backend (PocketBase) ======
VITE_PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=admin@versa.local
PB_ADMIN_PASSWORD=versapass123

# ====== AI Providers ======
# 留空则使用 mock 模式 (零成本)
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-3-5-sonnet-20241022
VITE_QWEN_API_KEY=
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====== Observability ======
VITE_SENTRY_DSN=
VITE_ANALYTICS_ENDPOINT=

# ====== Feature Flags ======
VITE_FEATURE_AI=true
VITE_FEATURE_PWA=true
VITE_FEATURE_CREATOR=true
VITE_FEATURE_ADMIN=true

# ====== Deployment ======
# 部署到 GitHub Pages 时
DEPLOY_TARGET=gh-pages
# 部署到自有服务器
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_KEY=
DEPLOY_REMOTE_DIR=/var/www/versa
